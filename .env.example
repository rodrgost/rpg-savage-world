# Firebase Web SDK (Frontend MVP)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Opcional (true para usar Auth/Firestore/Functions emuladores locais)
VITE_USE_FIREBASE_EMULATORS="false"

# OAuth2
OAUTH2_CLIENT_ID=""

# Backend HTTP (Nest legado/opcional)
PORT="3100"
VITE_BACKEND_URL="http://localhost:3100"

# Backend Firebase Admin (escolha 1 opção)
FIREBASE_PROJECT_ID=""
FIREBASE_SERVICE_ACCOUNT_PATH=""
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Narrador LLM (modelo de linguagem)
LLM_PROVIDER="gemini"

# DeepSeek (narrador, resumos e expansões de texto)
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="DeepSeek-V3.2"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_TEMPERATURE="0.4"
DEEPSEEK_NARRATE_START_TEMPERATURE="0.20"
DEEPSEEK_NARRATE_TURN_TEMPERATURE="0.15"
DEEPSEEK_SUMMARY_TEMPERATURE="0.15"
DEEPSEEK_SUMMARY_HISTORY_TEMPERATURE="0.10"
DEEPSEEK_MAX_OUTPUT_TOKENS="8192"
DEEPSEEK_WORLD_MAX_OUTPUT_TOKENS="8192"
DEEPSEEK_NARRATE_START_MAX_TOKENS="8192"
DEEPSEEK_NARRATE_TURN_MAX_TOKENS="8192"
DEEPSEEK_TIMEOUT_MS="45000"
DEEPSEEK_NARRATOR_TIMEOUT_MS="120000"
DEEPSEEK_CHARACTER_SUGGEST_TEMPERATURE="1.0"

# Gemini (continua sendo usado na geração de imagem)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com"
GEMINI_TEMPERATURE="0.4"
GEMINI_NARRATE_START_TEMPERATURE="0.25"
GEMINI_NARRATE_TURN_TEMPERATURE="0.20"
GEMINI_SUMMARY_TEMPERATURE="0.20"
GEMINI_SUMMARY_HISTORY_TEMPERATURE="0.15"
GEMINI_MAX_OUTPUT_TOKENS="8192"
GEMINI_WORLD_MAX_OUTPUT_TOKENS="2048"
GEMINI_TIMEOUT_MS="45000"
